<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>{{Model.report.Title}}</title>

    <style>
    {{asset "/core/accounting/journal-vouchers-list/v1/styles.css"}}
    </style>
</head>

<body>

    <!-- Topbar (canonical 3-column) -->
    <div class="topbar">
        <div class="company-block">
            <div class="logo">
                {{#if Model.context.company.HasLogo}}
                <img class="logo-img" src="{{Model.context.company.LogoUrl}}" alt="Logo" />
                {{else}}
                <div class="logo-fallback">{{Model.context.company.LogoInitials}}</div>
                {{/if}}
            </div>

            <div class="company-details">
                <div class="company-name">
                    {{#if Model.context.company.TradeName}}
                    {{Model.context.company.TradeName}}
                    {{else}}
                    {{Model.context.company.Name}}
                    {{/if}}
                </div>
                {{#if Model.context.company.Identification}}
                <div class="company-line mono">{{Model.context.company.Identification}}</div>
                {{/if}}
            </div>
        </div>

        <div class="report-title-block">
            <div class="report-meta-name">{{Model.context.metadata.ReportName}}</div>
            <div class="report-meta-title mono">{{Model.report.Title}}</div>
        </div>

        <div class="topbar-spacer"></div>
    </div>

    <!-- Data table -->
    <table class="rpt-table">
        <thead>
            <tr>
                {{#each Model.report.Columns}}
                <th>{{this}}</th>
                {{/each}}
            </tr>
        </thead>

        <tbody>
            {{#each Model.report.Rows}}

            {{#if IsSpacer}}
            <tr class="row-spacer"><td colspan="7"></td></tr>
            {{else}}

            {{#if IsGroupHeader}}
            <tr class="row-header">
                <td class="mono bold">{{Cells.[0]}}</td>
                <td class="mono muted">{{Cells.[1]}}</td>
                <td class="mono">{{Cells.[2]}}</td>
                <td colspan="4" class="muted italic">{{Cells.[3]}}</td>
            </tr>
            {{else}}

            {{#if IsSubtotal}}
            <tr class="row-subtotal">
                <td colspan="5" class="lbl-cell">{{Label}}</td>
                <td>{{Cells.[5]}}</td>
                <td>{{Cells.[6]}}</td>
            </tr>
            {{else}}

            {{#if IsTotal}}
            <tr class="row-total">
                <td colspan="5" class="lbl-cell">{{Label}}</td>
                <td>{{Cells.[5]}}</td>
                <td>{{Cells.[6]}}</td>
            </tr>
            {{else}}

            <tr class="row-data">
                <td class="mono">{{Cells.[0]}}</td>
                <td>{{Cells.[1]}}</td>
                <td>{{Cells.[2]}}</td>
                <td class="mono">{{Cells.[3]}}</td>
                <td class="mono">{{Cells.[4]}}</td>
                <td>{{Cells.[5]}}</td>
                <td>{{Cells.[6]}}</td>
            </tr>

            {{/if}}
            {{/if}}
            {{/if}}
            {{/if}}

            {{/each}}
        </tbody>
    </table>

    <!-- Signature block -->
    {{#if Model.context.signatures.show}}
    <div class="sig-block">
        <div class="sig-col">
            <div class="sig-line"></div>
            {{#if Model.context.signatures.preparedBy}}
            <div class="sig-name">{{Model.context.signatures.preparedBy}}</div>
            {{/if}}
            <div class="sig-label">{{Model.context.resources.[labels.preparedBy]}}</div>
        </div>
        <div class="sig-col">
            <div class="sig-line"></div>
            {{#if Model.context.signatures.reviewedBy}}
            <div class="sig-name">{{Model.context.signatures.reviewedBy}}</div>
            {{/if}}
            <div class="sig-label">{{Model.context.resources.[labels.reviewedBy]}}</div>
        </div>
        <div class="sig-col">
            <div class="sig-line"></div>
            {{#if Model.context.signatures.approvedBy}}
            <div class="sig-name">{{Model.context.signatures.approvedBy}}</div>
            {{/if}}
            <div class="sig-label">{{Model.context.resources.[labels.approvedBy]}}</div>
        </div>
    </div>
    {{/if}}

    <!-- Footer -->
    <div class="footer footer-two-cols">
        <div class="mono">{{Model.context.metadata.ReportName}}</div>
        <div>{{Model.context.metadata.GeneratedAt}}</div>
    </div>

</body>
</html>
