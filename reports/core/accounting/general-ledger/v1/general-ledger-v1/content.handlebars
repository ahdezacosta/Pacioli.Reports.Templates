<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>{{Model.report.Title}}</title>
    <style>
    {{asset "/core/accounting/general-ledger/v1/styles.css"}}
    </style>
</head>
<body>

    <!-- ── Header ─────────────────────────────────────────────── -->
    <div class="topbar">
        <div class="topbar-left">
            <span class="co-name">
                {{#if Model.context.company.TradeName}}{{Model.context.company.TradeName}}{{else}}{{Model.context.company.Name}}{{/if}}
            </span>
            {{#if Model.context.company.Identification}}
            <span class="topbar-sep">|</span>
            <span class="co-id">{{Model.context.company.Identification}}</span>
            {{/if}}
        </div>
        <div class="topbar-right">
            <span class="rpt-name">{{Model.context.metadata.ReportName}}</span>
            <span class="topbar-sep">|</span>
            <span class="rpt-title">{{Model.report.Title}}</span>
            <span class="topbar-sep">|</span>
            <span class="rpt-date">{{Model.context.metadata.GeneratedAt}}</span>
        </div>
    </div>

    <!-- ── Table ──────────────────────────────────────────────── -->
    <table class="rpt-table">
        <thead>
            <tr>
                {{#each Model.report.Columns}}
                <th>{{this}}</th>
                {{/each}}
            </tr>
        </thead>
        <tbody>
            {{#each Model.report.Rows}}

            {{#if IsSpacer}}
            <tr class="row-spacer"><td colspan="100"></td></tr>
            {{else}}

            {{#if IsGroupHeader}}
            <tr class="row-group-header">
                <td colspan="100">{{Label}}</td>
            </tr>
            {{else}}

            {{#if IsSectionHeader}}
            <tr class="row-section-header">
                <td colspan="100">{{Label}}</td>
            </tr>
            {{else}}

            {{#if IsTotal}}
            <tr class="row-total">
                {{#each Cells}}
                {{#if @first}}<td class="lbl-cell">{{../Label}}</td>{{else}}<td>{{this}}</td>{{/if}}
                {{/each}}
            </tr>
            {{else}}

            {{#if IsSubtotal}}
            <tr class="row-subtotal">
                {{#each Cells}}
                {{#if @first}}<td class="lbl-cell">{{../Label}}</td>{{else}}<td>{{this}}</td>{{/if}}
                {{/each}}
            </tr>
            {{else}}

            <tr class="row-data">
                {{#each Cells}}<td>{{this}}</td>{{/each}}
            </tr>

            {{/if}}{{/if}}{{/if}}{{/if}}{{/if}}

            {{/each}}
        </tbody>
    </table>

    <!-- ── Footer ─────────────────────────────────────────────── -->
    <div class="footer">
        <span>{{Model.context.metadata.ReportName}}</span>
        <span class="footer-sep">|</span>
        <span>{{Model.report.Title}}</span>
        <span class="footer-sep">|</span>
        <span>{{Model.context.metadata.GeneratedAt}}</span>
    </div>

</body>
</html>
