<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>{{Model.context.resources.[titles.journalEntry]}}</title>
    <style>
    {{asset "/core/accounting/journal-entry/v1/styles.css"}}
    </style>
</head>
<body>

    <!-- Topbar (canonical 3-column) -->
    <div class="topbar">
        <div class="company-block">
            <div class="logo">
                {{#if Model.context.company.HasLogo}}
                <img class="logo-img" src="{{Model.context.company.LogoUrl}}" alt="Logo" />
                {{else}}
                <div class="logo-fallback">{{Model.context.company.LogoInitials}}</div>
                {{/if}}
            </div>

            <div class="company-details">
                <div class="company-name">
                    {{#if Model.context.company.TradeName}}
                    {{Model.context.company.TradeName}}
                    {{else}}
                    {{Model.context.company.Name}}
                    {{/if}}
                </div>
                {{#if Model.context.company.Identification}}
                <div class="company-line mono">{{Model.context.company.Identification}}</div>
                {{/if}}
            </div>
        </div>

        <div class="report-title-block">
            <div class="report-meta-name">{{Model.context.resources.[titles.journalEntry]}}</div>
            <div class="report-meta-title mono">{{Model.model.header.journalEntryNumber}}</div>
            <div class="report-meta-sub muted">{{Model.context.resources.[labels.period]}}: <span class="mono">{{Model.context.period.PeriodKey}}</span></div>
        </div>

        <div class="topbar-spacer"></div>
    </div>

    <!-- Info block: Asiento · N° Diario · Fecha + Descripción -->
    <div class="info-block">
        <div class="info-cell">
            <div class="info-label">{{Model.context.resources.[labels.journalEntryNumber]}}</div>
            <div class="info-value mono bold">{{Model.model.header.journalEntryNumber}}</div>
        </div>
        <div class="info-cell">
            <div class="info-label">{{Model.context.resources.[labels.journalNumber]}}</div>
            <div class="info-value mono">{{#if Model.model.header.journalNumber}}{{Model.model.header.journalNumber}}{{else}}—{{/if}}</div>
        </div>
        <div class="info-cell">
            <div class="info-label">{{Model.context.resources.[labels.journalDate]}}</div>
            <div class="info-value mono">{{Model.model.header.journalDateText}}</div>
        </div>
        <div class="info-cell span3">
            <div class="info-label">{{Model.context.resources.[labels.description]}}</div>
            <div class="info-value">{{#if Model.model.header.description}}{{Model.model.header.description}}{{else}}—{{/if}}</div>
        </div>
        {{#if Model.model.header.voidedAtText}}
        <div class="info-cell">
            <div class="info-label">{{Model.context.resources.[labels.voidedAt]}}</div>
            <div class="info-value mono">{{Model.model.header.voidedAtText}}</div>
        </div>
        <div class="info-cell span2">
            <div class="info-label">{{Model.context.resources.[labels.voidReason]}}</div>
            <div class="info-value">{{#if Model.model.header.voidReason}}{{Model.model.header.voidReason}}{{else}}—{{/if}}</div>
        </div>
        {{/if}}
    </div>

    <!-- Lines table -->
    <table class="rpt-table">
        <thead>
            <tr>
                <th>{{Model.context.resources.[columns.accountCode]}}</th>
                <th>{{Model.context.resources.[columns.accountName]}}</th>
                <th>{{Model.context.resources.[columns.description]}}</th>
                <th>{{Model.context.resources.[columns.costcenter]}}</th>
                <th>{{Model.context.resources.[columns.subcostcenter]}}</th>
                <th>{{Model.context.resources.[columns.debit]}}</th>
                <th>{{Model.context.resources.[columns.credit]}}</th>
            </tr>
        </thead>
        <tbody>
            {{#each Model.model.lines}}
            <tr>
                <td class="mono">{{#if accountCode}}{{accountCode}}{{else}}—{{/if}}</td>
                <td>{{#if accountName}}{{accountName}}{{else}}—{{/if}}</td>
                <td>{{#if description}}{{description}}{{else}}—{{/if}}</td>
                <td class="mono">{{#if costCenterText}}{{costCenterText}}{{else}}—{{/if}}</td>
                <td class="mono">{{#if subCostCenterText}}{{subCostCenterText}}{{else}}—{{/if}}</td>
                <td>{{debitText}}</td>
                <td>{{creditText}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <!-- Totals -->
    <div class="totals">
        <div class="total-box">
            <div class="t-label">{{Model.context.resources.[labels.totalDebit]}}</div>
            <div class="t-value">{{Model.model.totals.debitText}}</div>
        </div>
        <div class="total-box">
            <div class="t-label">{{Model.context.resources.[labels.totalCredit]}}</div>
            <div class="t-value">{{Model.model.totals.creditText}}</div>
        </div>
        <div class="total-box">
            <div class="t-label">{{Model.context.resources.[labels.balance]}}</div>
            <div class="t-value">{{Model.model.totals.diffText}}</div>
        </div>
    </div>

    <!-- Signature block -->
    {{#if Model.context.signatures.show}}
    <div class="sig-block">
        <div class="sig-col">
            <div class="sig-line"></div>
            {{#if Model.context.signatures.preparedBy}}
            <div class="sig-name">{{Model.context.signatures.preparedBy}}</div>
            {{/if}}
            <div class="sig-label">{{Model.context.resources.[labels.preparedBy]}}</div>
        </div>
        <div class="sig-col">
            <div class="sig-line"></div>
            {{#if Model.context.signatures.reviewedBy}}
            <div class="sig-name">{{Model.context.signatures.reviewedBy}}</div>
            {{/if}}
            <div class="sig-label">{{Model.context.resources.[labels.reviewedBy]}}</div>
        </div>
        <div class="sig-col">
            <div class="sig-line"></div>
            {{#if Model.context.signatures.approvedBy}}
            <div class="sig-name">{{Model.context.signatures.approvedBy}}</div>
            {{/if}}
            <div class="sig-label">{{Model.context.resources.[labels.approvedBy]}}</div>
        </div>
    </div>
    {{/if}}

    <!-- Footer -->
    <div class="footer">
        <span><span class="mono">{{ReportKey}}</span><span class="footer-sep">|</span><span class="mono">{{ReportVersion}}</span></span>
        <span>{{Model.context.resources.[labels.generatedAt]}}: <span class="mono">{{Model.context.metadata.GeneratedAt}}</span></span>
    </div>

</body>
</html>
