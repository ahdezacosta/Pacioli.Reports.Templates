<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>{{Model.context.resources.[titles.journalEntry]}}</title>

    <style>
    {{asset "/core/accounting/journal-entry/v1/styles.css"}}
    </style>
</head>

<body>

    <!-- Company + Period header -->
    <div class="topbar">
        <div class="company-block">
            <div class="logo">
                {{#if Model.context.company.HasLogo}}
                <img class="logo-img" src="{{Model.context.company.LogoUrl}}" alt="Logo" />
                {{else}}
                <div class="logo-fallback">{{Model.context.company.LogoInitials}}</div>
                {{/if}}
            </div>

            <div class="company-details">
                <div class="company-name">
                    {{#if Model.context.company.TradeName}}
                    {{Model.context.company.TradeName}}
                    {{else}}
                    {{Model.context.company.Name}}
                    {{/if}}
                </div>

                {{#if Model.context.company.Identification}}
                <div class="company-line">
                    <span class="muted">{{Model.context.resources.[labels.identification]}}:</span>
                    <span class="mono">{{Model.context.company.Identification}}</span>
                </div>
                {{/if}}

                {{#if Model.context.company.Email}}
                <div class="company-line mono">{{Model.context.company.Email}}</div>
                {{/if}}

                {{#if Model.context.company.Phone}}
                <div class="company-line mono">{{Model.context.company.Phone}}</div>
                {{/if}}

                {{#if Model.context.company.Website}}
                <div class="company-line mono">{{Model.context.company.Website}}</div>
                {{/if}}
            </div>
        </div>

        <div class="period-block">
            <div class="period-title">{{Model.context.resources.[labels.period]}}</div>
            <div class="period-key mono">{{Model.context.period.PeriodKey}}</div>

            <div class="period-range muted">
                {{Model.context.resources.[labels.from]}} <span class="mono">{{Model.context.period.StartDate}}</span>
                •
                {{Model.context.resources.[labels.to]}} <span class="mono">{{Model.context.period.EndDate}}</span>
            </div>
        </div>
    </div>

    <!-- Header (journal entry) -->
    <div class="header">
        <div>
            <h1 class="title">{{Model.context.resources.[titles.journalEntry]}}</h1>
            <div class="subtitle">
                <span class="mono">{{Model.model.header.id}}</span>
            </div>
        </div>

        <div>
            {{#if Model.model.totals.balanced}}
            <span class="chip ok">{{Model.context.resources.[labels.balanced]}}</span>
            {{else}}
            <span class="chip bad">{{Model.context.resources.[labels.unbalanced]}}</span>
            {{/if}}
        </div>
    </div>

    <!-- Card -->
    <div class="card">
        <div class="row">
            <div class="col">
                <div class="kv">
                    <div class="k">{{Model.context.resources.[labels.journalEntryNumber]}}</div>
                    <div class="v"><strong>{{Model.model.header.journalEntryNumber}}</strong></div>

                    <div class="k">{{Model.context.resources.[labels.journalNumber]}}</div>
                    <div class="v">{{#if Model.model.header.journalNumber}}{{Model.model.header.journalNumber}}{{else}}—{{/if}}</div>

                    <div class="k">{{Model.context.resources.[labels.journalDate]}}</div>
                    <div class="v">{{Model.model.header.journalDateText}}</div>

                    <div class="k">{{Model.context.resources.[labels.origin]}}</div>
                    <div class="v">{{Model.model.header.originText}}</div>

                    <div class="k">{{Model.context.resources.[labels.status]}}</div>
                    <div class="v">{{Model.model.header.statusText}}</div>
                </div>
            </div>

            <div class="col">
                <div class="kv">
                    <div class="k">{{Model.context.resources.[labels.reference]}}</div>
                    <div class="v">{{#if Model.model.header.reference}}{{Model.model.header.reference}}{{else}}—{{/if}}</div>

                    <div class="k">{{Model.context.resources.[labels.description]}}</div>
                    <div class="v">{{#if Model.model.header.description}}{{Model.model.header.description}}{{else}}—{{/if}}</div>

                    <div class="k">{{Model.context.resources.[labels.postedAt]}}</div>
                    <div class="v">{{#if Model.model.header.postedAtText}}{{Model.model.header.postedAtText}}{{else}}—{{/if}}</div>

                    <div class="k">{{Model.context.resources.[labels.voidedAt]}}</div>
                    <div class="v">{{#if Model.model.header.voidedAtText}}{{Model.model.header.voidedAtText}}{{else}}—{{/if}}</div>

                    <div class="k">{{Model.context.resources.[labels.voidReason]}}</div>
                    <div class="v">{{#if Model.model.header.voidReason}}{{Model.model.header.voidReason}}{{else}}—{{/if}}</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Table -->
    <table>
        <thead>
            <tr>
                <th class="w-id">{{Model.context.resources.[columns.account]}}</th>
                <th class="w-desc">{{Model.context.resources.[columns.description]}}</th>
                <th class="w-cc">{{Model.context.resources.[columns.costcenter]}}</th>
                <th class="w-cc">{{Model.context.resources.[columns.subcostcenter]}}</th>
                <th class="w-money right">{{Model.context.resources.[columns.debit]}}</th>
                <th class="w-money right">{{Model.context.resources.[columns.credit]}}</th>
            </tr>
        </thead>

        <tbody>
            {{#each Model.model.lines}}
            <tr>
                <td class="mono">{{#if accountText}}{{accountText}}{{else}}—{{/if}}</td>
                <td>{{#if description}}{{description}}{{else}}—{{/if}}</td>
                <td class="mono">{{#if costCenterText}}{{costCenterText}}{{else}}—{{/if}}</td>
                <td class="mono">{{#if subCostCenterText}}{{subCostCenterText}}{{else}}—{{/if}}</td>
                <td class="right nowrap">{{debitText}}</td>
                <td class="right nowrap">{{creditText}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <!-- Totals -->
    <div class="totals">
        <div class="total-box">
            <div class="label">{{Model.context.resources.[labels.totalDebit]}}</div>
            <div class="value right">{{Model.model.totals.debitText}}</div>
        </div>

        <div class="total-box">
            <div class="label">{{Model.context.resources.[labels.totalCredit]}}</div>
            <div class="value right">{{Model.model.totals.creditText}}</div>
        </div>

        <div class="total-box">
            <div class="label">{{Model.context.resources.[labels.balance]}}</div>
            <div class="value right">{{Model.model.totals.diffText}}</div>
        </div>
    </div>

    <!-- Footer -->
    <div class="footer footer-two-cols">
        <div>Reporte: <span class="mono">{{ReportKey}} - ver: {{ReportVersion}}</span></div>
        <div>{{Model.context.resources.[labels.generatedAt]}}: <span class="mono">{{Model.context.metadata.GeneratedAtUtc}}</span></div>
    </div>

</body>
</html>
