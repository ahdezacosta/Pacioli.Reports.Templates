<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <title>{{Model.context.resources.[titles.balanceSheet]}}</title>

    <style>
    {{asset "/core/accounting/balance-sheet/v1/styles.css"}}
    </style>
</head>

<body>

    <!-- Company + Period header -->
    <div class="topbar">
        <div class="company-block">
            <div class="logo">
                {{#if Model.context.company.HasLogo}}
                <img class="logo-img" src="{{Model.context.company.LogoUrl}}" alt="Logo" />
                {{else}}
                <div class="logo-fallback">{{Model.context.company.LogoInitials}}</div>
                {{/if}}
            </div>

            <div class="company-details">
                <div class="company-name">
                    {{#if Model.context.company.TradeName}}
                    {{Model.context.company.TradeName}}
                    {{else}}
                    {{Model.context.company.Name}}
                    {{/if}}
                </div>

                {{#if Model.context.company.Identification}}
                <div class="company-line">
                    <span class="muted">{{Model.context.resources.[labels.identification]}}:</span>
                    <span class="mono">{{Model.context.company.Identification}}</span>
                </div>
                {{/if}}

                {{#if Model.context.company.Email}}
                <div class="company-line mono">{{Model.context.company.Email}}</div>
                {{/if}}

                {{#if Model.context.company.Phone}}
                <div class="company-line mono">{{Model.context.company.Phone}}</div>
                {{/if}}
            </div>
        </div>

        <div class="period-block">
            {{#if Model.context.period}}
                <div class="period-title">{{Model.context.resources.[labels.period]}}</div>
                <div class="period-key mono">{{Model.context.period.PeriodKey}}</div>
                <div class="period-range muted">
                    {{Model.context.resources.[labels.asOf]}} <span class="mono">{{Model.model.filters.asOf}}</span>
                </div>
            {{else}}
                <div class="period-title">{{Model.context.resources.[labels.asOf]}}</div>
                <div class="period-key mono">{{Model.model.filters.asOf}}</div>
            {{/if}}
        </div>
    </div>

    <!-- Report title -->
    <div class="header">
        <div>
            <h1 class="title">{{Model.context.resources.[titles.balanceSheet]}}</h1>
            <div class="subtitle muted">
                {{Model.context.resources.[labels.asOf]}} <span class="mono">{{Model.model.filters.asOf}}</span>
            </div>
        </div>
    </div>

    {{#if Model.model.sections.length}}

        {{#each Model.model.sections}}
        <!-- Section: {{accountType}} -->
        <div class="section">
            <div class="section-header">{{label}}</div>
            <table class="movements-table">
                <thead>
                    <tr>
                        <th class="w-code">{{../Model.context.resources.[columns.code]}}</th>
                        <th class="w-desc">{{../Model.context.resources.[columns.account]}}</th>
                        <th class="w-money right">{{../Model.context.resources.[columns.openingBalance]}}</th>
                        <th class="w-money right">{{../Model.context.resources.[columns.periodDebit]}}</th>
                        <th class="w-money right">{{../Model.context.resources.[columns.periodCredit]}}</th>
                        <th class="w-money right">{{../Model.context.resources.[columns.closingBalance]}}</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each rows}}
                    <tr>
                        <td class="mono nowrap">{{code}}</td>
                        <td class="tb-account-cell tb-lvl-{{level}} mono">
                            {{#if name}}{{name}}{{else}}{{../../Model.context.resources.[labels.notAvailable]}}{{/if}}
                        </td>
                        <td class="right nowrap">{{openingBalanceText}}</td>
                        <td class="right nowrap">{{periodDebitText}}</td>
                        <td class="right nowrap">{{periodCreditText}}</td>
                        <td class="right nowrap">{{closingBalanceText}}</td>
                    </tr>
                    {{/each}}
                </tbody>
                <tfoot>
                    <tr>
                        <td></td>
                        <td class="right" style="font-weight:600;">{{../Model.context.resources.[labels.totals]}}</td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td class="right nowrap"><strong>{{subtotalText}}</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
        {{/each}}

        <!-- Grand summary -->
        <table class="grand-total-table">
            <tr>
                <td style="width:50%; font-weight:600;">{{Model.context.resources.[labels.totalAssets]}}</td>
                <td style="width:25%; text-align:right;" class="mono">{{Model.model.totalAssetsText}}</td>
                <td style="width:25%;"></td>
            </tr>
            <tr>
                <td style="font-weight:600;">{{Model.context.resources.[labels.totalLiabilities]}}</td>
                <td style="text-align:right;" class="mono">{{Model.model.totalLiabilitiesText}}</td>
                <td></td>
            </tr>
            <tr>
                <td style="font-weight:600;">{{Model.context.resources.[labels.totalEquity]}}</td>
                <td style="text-align:right;" class="mono">{{Model.model.totalEquityText}}</td>
                <td></td>
            </tr>
            <tr class="grand-total-row {{#unless Model.model.isBalanced}}grand-total-unbalanced{{/unless}}">
                <td style="font-size:13px;">{{Model.context.resources.[labels.totalLiabilitiesAndEquity]}}</td>
                <td style="text-align:right; font-size:13px;" class="mono">{{Model.model.totalLiabilitiesAndEquityText}}</td>
                <td></td>
            </tr>
        </table>

    {{else}}
        <p class="muted" style="margin-top:24px; text-align:center;">
            {{Model.context.resources.[labels.notAvailable]}}
        </p>
    {{/if}}

    <!-- Footer -->
    <div class="footer">
        <div>
            {{Model.context.resources.[labels.report]}}:
            <span class="mono">{{ReportKey}} • {{Model.context.resources.[labels.version]}}: {{ReportVersion}}</span>
        </div>
        <div>
            {{Model.context.resources.[labels.generatedAt]}}:
            <span class="mono">{{Model.context.metadata.GeneratedAtUtc}}</span>
        </div>
    </div>

</body>
</html>
