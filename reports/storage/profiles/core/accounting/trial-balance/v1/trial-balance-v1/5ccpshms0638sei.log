{"type":"error","timestamp":1771375492511,"entity":{"shortid":"su_tAivb0e","name":"trial-balance-v1","content":"<!doctype html>\r\n<html>\r\n<head>\r\n    <meta charset=\"utf-8\" />\r\n    <title>{{Model.context.resources.[titles.generalLedger]}}</title>\r\n\r\n    <style>\r\n    {{asset \"/core/accounting/trial-balance/v1/styles.css\"}}\r\n    </style>\r\n</head>\r\n\r\n<body>\r\n\r\n    <!-- Company + Period header -->\r\n    <div class=\"topbar\">\r\n        <div class=\"company-block\">\r\n            <div class=\"logo\">\r\n                {{#if Model.context.company.HasLogo}}\r\n                <img class=\"logo-img\" src=\"{{Model.context.company.LogoUrl}}\" alt=\"Logo\" />\r\n                {{else}}\r\n                <div class=\"logo-fallback\">{{Model.context.company.LogoInitials}}</div>\r\n                {{/if}}\r\n            </div>\r\n\r\n            <div class=\"company-details\">\r\n                <div class=\"company-name\">\r\n                    {{#if Model.context.company.TradeName}}\r\n                    {{Model.context.company.TradeName}}\r\n                    {{else}}\r\n                    {{Model.context.company.Name}}\r\n                    {{/if}}\r\n                </div>\r\n\r\n                {{#if Model.context.company.Identification}}\r\n                <div class=\"company-line\">\r\n                    <span class=\"muted\">{{Model.context.resources.[labels.identification]}}:</span>\r\n                    <span class=\"mono\">{{Model.context.company.Identification}}</span>\r\n                </div>\r\n                {{/if}}\r\n\r\n                {{#if Model.context.company.Email}}\r\n                <div class=\"company-line mono\">{{Model.context.company.Email}}</div>\r\n                {{/if}}\r\n\r\n                {{#if Model.context.company.Phone}}\r\n                <div class=\"company-line mono\">{{Model.context.company.Phone}}</div>\r\n                {{/if}}\r\n\r\n                {{#if Model.context.company.Website}}\r\n                <div class=\"company-line mono\">{{Model.context.company.Website}}</div>\r\n                {{/if}}\r\n            </div>\r\n        </div>\r\n\r\n        <div class=\"period-block\">\r\n            {{#if Model.context.period}}\r\n            <div class=\"period-title\">{{Model.context.resources.[labels.period]}}</div>\r\n            <div class=\"period-key mono\">{{Model.context.period.PeriodKey}}</div>\r\n\r\n            <div class=\"period-range muted\">\r\n                {{Model.context.resources.[labels.from]}} <span class=\"mono\">{{Model.context.period.StartDate}}</span>\r\n                •\r\n                {{Model.context.resources.[labels.to]}} <span class=\"mono\">{{Model.context.period.EndDate}}</span>\r\n            </div>\r\n            {{else}}\r\n            <div class=\"period-title\">{{Model.context.resources.[labels.dateRange]}}</div>\r\n            <div class=\"period-key mono\">{{Model.model.filters.fromDateText}} • {{Model.model.filters.toDateText}}</div>\r\n\r\n            <div class=\"period-range muted\">\r\n                {{#if Model.model.filters.onlyPosted}}\r\n                {{Model.context.resources.[labels.onlyPosted]}}\r\n                {{else}}\r\n                {{Model.context.resources.[labels.includeDrafts]}}\r\n                {{/if}}\r\n            </div>\r\n            {{/if}}\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Report header -->\r\n    <div class=\"header\">\r\n        <div>\r\n            <h1 class=\"title\">{{Model.context.resources.[titles.generalLedger]}}</h1>\r\n\r\n            <div class=\"subtitle\">\r\n                <span class=\"muted\">{{Model.context.resources.[labels.from]}}</span>\r\n                <span class=\"mono\">{{Model.model.filters.fromDateText}}</span>\r\n                <span class=\"muted\">•</span>\r\n                <span class=\"muted\">{{Model.context.resources.[labels.to]}}</span>\r\n                <span class=\"mono\">{{Model.model.filters.toDateText}}</span>\r\n\r\n                {{#if Model.model.filters.periodId}}\r\n                <span class=\"muted\">•</span>\r\n                <span class=\"muted\">{{Model.context.resources.[labels.periodId]}}</span>\r\n                <span class=\"mono\">{{Model.model.filters.periodId}}</span>\r\n                {{/if}}\r\n            </div>\r\n        </div>\r\n\r\n        <div class=\"header-chips\">\r\n            {{#if Model.model.filters.onlyPosted}}\r\n            <span class=\"chip ok\">{{Model.context.resources.[labels.onlyPosted]}}</span>\r\n            {{else}}\r\n            <span class=\"chip\">\r\n                {{Model.context.resources.[labels.onlyPosted]}}: {{Model.context.resources.[labels.no]}}\r\n            </span>\r\n            {{/if}}\r\n\r\n            {{#if Model.model.filters.includeVoided}}\r\n            <span class=\"chip bad\">{{Model.context.resources.[labels.includeVoided]}}</span>\r\n            {{/if}}\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Filters card -->\r\n    <div class=\"card\">\r\n        <div class=\"row\">\r\n            <div class=\"col\">\r\n                <div class=\"kv\">\r\n                    <div class=\"k\">{{Model.context.resources.[labels.from]}}</div>\r\n                    <div class=\"v mono\">{{Model.model.filters.fromDateText}}</div>\r\n\r\n                    <div class=\"k\">{{Model.context.resources.[labels.to]}}</div>\r\n                    <div class=\"v mono\">{{Model.model.filters.toDateText}}</div>\r\n\r\n                    <div class=\"k\">{{Model.context.resources.[labels.onlyPosted]}}</div>\r\n                    <div class=\"v\">\r\n                        {{#if Model.model.filters.onlyPosted}}\r\n                        {{Model.context.resources.[labels.yes]}}\r\n                        {{else}}\r\n                        {{Model.context.resources.[labels.no]}}\r\n                        {{/if}}\r\n                    </div>\r\n\r\n                    <div class=\"k\">{{Model.context.resources.[labels.includeVoided]}}</div>\r\n                    <div class=\"v\">\r\n                        {{#if Model.model.filters.includeVoided}}\r\n                        {{Model.context.resources.[labels.yes]}}\r\n                        {{else}}\r\n                        {{Model.context.resources.[labels.no]}}\r\n                        {{/if}}\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"col\">\r\n                <div class=\"kv\">\r\n                    <div class=\"k\">{{Model.context.resources.[labels.includeOpeningBalance]}}</div>\r\n                    <div class=\"v\">\r\n                        {{#if Model.model.filters.includeOpeningBalance}}\r\n                        {{Model.context.resources.[labels.yes]}}\r\n                        {{else}}\r\n                        {{Model.context.resources.[labels.no]}}\r\n                        {{/if}}\r\n                    </div>\r\n\r\n                    <div class=\"k\">{{Model.context.resources.[labels.includeRunningBalance]}}</div>\r\n                    <div class=\"v\">\r\n                        {{#if Model.model.filters.includeRunningBalance}}\r\n                        {{Model.context.resources.[labels.yes]}}\r\n                        {{else}}\r\n                        {{Model.context.resources.[labels.no]}}\r\n                        {{/if}}\r\n                    </div>\r\n\r\n                    <div class=\"k\">{{Model.context.resources.[labels.accountFilter]}}</div>\r\n                    <div class=\"v\">\r\n                        {{#if Model.model.filters.accountIds}}\r\n                        <span class=\"mono\">{{Model.model.filters.accountIds}}</span>\r\n                        {{else}}\r\n                        {{Model.context.resources.[labels.notAvailable]}}\r\n                        {{/if}}\r\n                    </div>\r\n\r\n                    <div class=\"k\">{{Model.context.resources.[labels.period]}}</div>\r\n                    <div class=\"v\">\r\n                        {{#if Model.context.period}}\r\n                        <span class=\"mono\">{{Model.context.period.PeriodKey}}</span>\r\n                        {{else}}\r\n                        {{Model.context.resources.[labels.notAvailable]}}\r\n                        {{/if}}\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Accounts -->\r\n    {{#each Model.model.accounts}}\r\n\r\n    {{#unless @first}}\r\n    <div class=\"account-gap\"></div>\r\n    {{/unless}}\r\n\r\n    <!-- Account card -->\r\n    <div class=\"card account-card\">\r\n        <div class=\"row\">\r\n            <div class=\"col\">\r\n                <div class=\"account-card-title\">\r\n                    <div class=\"k\">{{../Model.context.resources.[labels.account]}}</div>\r\n\r\n                    <div class=\"v\">\r\n                        <div class=\"mono account-code\">\r\n                            {{#if code}}{{code}}{{else}}{{../Model.context.resources.[labels.notAvailable]}}{{/if}}\r\n                        </div>\r\n                        <div class=\"account-name\">\r\n                            {{#if name}}{{name}}{{else}}{{../Model.context.resources.[labels.notAvailable]}}{{/if}}\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"col\">\r\n                <div class=\"kv kv-money\">\r\n                    <div class=\"total-box\">\r\n                        <div class=\"label\">{{../Model.context.resources.[labels.openingBalance]}}</div>\r\n                        <div class=\"value right\">{{#if openingBalanceText}}{{openingBalanceText}}{{else}}{{../Model.context.resources.[labels.notAvailable]}}{{/if}}</div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Movements table -->\r\n    <table class=\"movements-table\">\r\n        <thead>\r\n            <tr>\r\n                <th class=\"w-date\">{{../Model.context.resources.[columns.date]}}</th>\r\n                <th class=\"w-jn\">{{../Model.context.resources.[columns.journalEntryNumber]}}</th>\r\n                <th class=\"w-jn\">{{../Model.context.resources.[columns.journalNumber]}}</th>\r\n                <th class=\"w-desc\">{{../Model.context.resources.[columns.description]}}</th>\r\n                <th class=\"w-cc\">{{../Model.context.resources.[columns.costcenter]}}</th>\r\n                <th class=\"w-cc\">{{../Model.context.resources.[columns.subcostcenter]}}</th>\r\n                <th class=\"w-money right\">{{../Model.context.resources.[columns.debit]}}</th>\r\n                <th class=\"w-money right\">{{../Model.context.resources.[columns.credit]}}</th>\r\n                <th class=\"w-money right\">{{../Model.context.resources.[columns.runningBalance]}}</th>\r\n            </tr>\r\n        </thead>\r\n\r\n        <tbody>\r\n            {{#if movements.length}}\r\n            {{#each movements}}\r\n            <tr>\r\n                <td class=\"mono nowrap\">{{dateText}}</td>\r\n                <td class=\"mono nowrap\">{{#if journalEntryNumber}}{{journalEntryNumber}}{{else}}{{../Model.context.resources.[labels.notAvailable]}}{{/if}}</td>\r\n                <td class=\"mono nowrap\">{{#if journalNumber}}{{journalNumber}}{{else}}{{../Model.context.resources.[labels.notAvailable]}}{{/if}}</td>\r\n                <td>{{#if description}}{{description}}{{else}}{{../Model.context.resources.[labels.notAvailable]}}{{/if}}</td>\r\n                <td class=\"mono\">{{#if costCenterCode}}{{costCenterCode}}{{else}}{{../Model.context.resources.[labels.notAvailable]}}{{/if}}</td>\r\n                <td class=\"mono\">{{#if subCostCenterCode}}{{subCostCenterCode}}{{else}}{{../Model.context.resources.[labels.notAvailable]}}{{/if}}</td>\r\n                <td class=\"right nowrap\">{{debitText}}</td>\r\n                <td class=\"right nowrap\">{{creditText}}</td>\r\n                <td class=\"right nowrap\">\r\n                    {{#if runningBalanceText}}{{runningBalanceText}}{{else}}{{../Model.context.resources.[labels.notAvailable]}}{{/if}}\r\n                </td>\r\n            </tr>\r\n            {{/each}}\r\n            {{else}}\r\n            <tr>\r\n                <td colspan=\"9\" class=\"muted\">{{../Model.context.resources.[labels.noMovements]}}</td>\r\n            </tr>\r\n            {{/if}}\r\n        </tbody>\r\n        {{#if movements.length}}\r\n        <tfoot>\r\n            <tr class=\"account-totals-row\">\r\n                <td></td>\r\n                <td></td>\r\n                <td></td>\r\n                <td></td>\r\n                <td></td>\r\n                <td class=\"totals-label right\">{{../Model.context.resources.[labels.totals]}}</td>\r\n\r\n                <td class=\"money right nowrap\"><strong>{{totals.debitText}}</strong></td>\r\n                <td class=\"money right nowrap\"><strong>{{totals.creditText}}</strong></td>\r\n                <td class=\"money right nowrap\"><strong>{{closingBalanceText}}</strong></td>\r\n            </tr>\r\n        </tfoot>\r\n        {{/if}}\r\n\r\n\r\n\r\n    </table>\r\n\r\n    {{/each}}\r\n\r\n    <!-- Grand totals -->\r\n    <div class=\"totals\">\r\n        <div class=\"total-box\">\r\n            <div class=\"label\">{{Model.context.resources.[labels.totalDebit]}}</div>\r\n            <div class=\"value right\">{{Model.model.totals.debitText}}</div>\r\n        </div>\r\n\r\n        <div class=\"total-box\">\r\n            <div class=\"label\">{{Model.context.resources.[labels.totalCredit]}}</div>\r\n            <div class=\"value right\">{{Model.model.totals.creditText}}</div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Footer -->\r\n    <div class=\"footer footer-two-cols\">\r\n        <div>\r\n            {{Model.context.resources.[labels.report]}}: