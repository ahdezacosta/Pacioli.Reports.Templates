{"type":"error","timestamp":1769046741693,"entity":{"shortid":"kYiLmEiiNm","name":"journal-entry-v1","content":"<!doctype html>\r\n<html>\r\n<head>\r\n  <meta charset=\"utf-8\" />\r\n  <title>{{lookup context.resources \"titles.journalEntry\"}}</title>\r\n\r\n  <style>\r\n    {{asset \"/core/accounting/journal-entry/v3/styles.css\"}}\r\n  </style>\r\n</head>\r\n\r\n<body>\r\n\r\n  <!-- Company + Period header -->\r\n  <div class=\"card\">\r\n    <div class=\"row\">\r\n      <div class=\"col\">\r\n        {{#if context.company.LogoUrl}}\r\n          <div>\r\n            <img src=\"{{context.company.LogoUrl}}\" alt=\"Logo\" />\r\n          </div>\r\n        {{/if}}\r\n\r\n        <div><strong>{{context.company.TradeName}}</strong></div>\r\n\r\n        <div class=\"muted\">\r\n          {{lookup context.resources \"labels.identification\"}}:\r\n          <span class=\"mono\">{{context.company.Identification}}</span>\r\n        </div>\r\n\r\n        {{#if context.company.Email}}\r\n          <div class=\"muted\">{{context.company.Email}}</div>\r\n        {{/if}}\r\n\r\n        {{#if context.company.Phone}}\r\n          <div class=\"muted\">{{context.company.Phone}}</div>\r\n        {{/if}}\r\n      </div>\r\n\r\n      <div class=\"col\">\r\n        <div class=\"kv\">\r\n          <div class=\"k\">{{lookup context.resources \"labels.period\"}}</div>\r\n          <div class=\"v mono\">{{context.period.PeriodKey}}</div>\r\n\r\n          <div class=\"k\">{{lookup context.resources \"labels.from\"}}</div>\r\n          <div class=\"v mono\">{{context.period.StartDate}}</div>\r\n\r\n          <div class=\"k\">{{lookup context.resources \"labels.to\"}}</div>\r\n          <div class=\"v mono\">{{context.period.EndDate}}</div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- Header -->\r\n  <div class=\"header\">\r\n    <div>\r\n      <h1 class=\"title\">{{lookup context.resources \"titles.journalEntry\"}}</h1>\r\n      <div class=\"subtitle\">\r\n        <span class=\"mono\">{{model.header.id}}</span>\r\n      </div>\r\n    </div>\r\n\r\n    <div>\r\n      {{#if model.totals.balanced}}\r\n        <span class=\"chip ok\">{{lookup context.resources \"labels.balanced\"}}</span>\r\n      {{else}}\r\n        <span class=\"chip bad\">{{lookup context.resources \"labels.unbalanced\"}}</span>\r\n      {{/if}}\r\n    </div>\r\n  </div>\r\n\r\n  <!-- Card -->\r\n  <div class=\"card\">\r\n    <div class=\"row\">\r\n      <div class=\"col\">\r\n        <div class=\"kv\">\r\n          <div class=\"k\">{{lookup context.resources \"labels.journalEntryNumber\"}}</div>\r\n          <div class=\"v\"><strong>{{model.header.journalEntryNumber}}</strong></div>\r\n\r\n          <div class=\"k\">{{lookup context.resources \"labels.journalNumber\"}}</div>\r\n          <div class=\"v\">{{#if model.header.journalNumber}}{{model.header.journalNumber}}{{else}}—{{/if}}</div>\r\n\r\n          <div class=\"k\">{{lookup context.resources \"labels.journalDate\"}}</div>\r\n          <div class=\"v\">{{model.header.journalDateText}}</div>\r\n\r\n          <div class=\"k\">{{lookup context.resources \"labels.origin\"}}</div>\r\n          <div class=\"v\">{{model.header.originText}}</div>\r\n\r\n          <div class=\"k\">{{lookup context.resources \"labels.status\"}}</div>\r\n          <div class=\"v\">{{model.header.statusText}}</div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"col\">\r\n        <div class=\"kv\">\r\n          <div class=\"k\">{{lookup context.resources \"labels.reference\"}}</div>\r\n          <div class=\"v\">{{#if model.header.reference}}{{model.header.reference}}{{else}}—{{/if}}</div>\r\n\r\n          <div class=\"k\">{{lookup context.resources \"labels.description\"}}</div>\r\n          <div class=\"v\">{{#if model.header.description}}{{model.header.description}}{{else}}—{{/if}}</div>\r\n\r\n          <div class=\"k\">{{lookup context.resources \"labels.postedAt\"}}</div>\r\n          <div class=\"v\">{{#if model.header.postedAtText}}{{model.header.postedAtText}}{{else}}—{{/if}}</div>\r\n\r\n          <div class=\"k\">{{lookup context.resources \"labels.voidedAt\"}}</div>\r\n          <div class=\"v\">{{#if model.header.voidedAtText}}{{model.header.voidedAtText}}{{else}}—{{/if}}</div>\r\n\r\n          <div class=\"k\">{{lookup context.resources \"labels.voidReason\"}}</div>\r\n          <div class=\"v\">{{#if model.header.voidReason}}{{model.header.voidReason}}{{else}}—{{/if}}</div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- Table -->\r\n  <table>\r\n    <thead>\r\n      <tr>\r\n        <th class=\"w-id\">{{lookup context.resources \"columns.account\"}}</th>\r\n        <th class=\"w-desc\">{{lookup context.resources \"columns.description\"}}</th>\r\n        <th class=\"w-cc\">{{lookup context.resources \"columns.costcenter\"}}</th>\r\n        <th class=\"w-cc\">{{lookup context.resources \"columns.subcostcenter\"}}</th>\r\n        <th class=\"w-money right\">{{lookup context.resources \"columns.debit\"}}</th>\r\n        <th class=\"w-money right\">{{lookup context.resources \"columns.credit\"}}</th>\r\n      </tr>\r\n    </thead>\r\n\r\n    <tbody>\r\n      {{#each model.lines}}\r\n      <tr>\r\n        <td class=\"mono\">{{#if accountText}}{{accountText}}{{else}}—{{/if}}</td>\r\n        <td>{{#if description}}{{description}}{{else}}—{{/if}}</td>\r\n        <td class=\"mono\">{{#if costCenterText}}{{costCenterText}}{{else}}—{{/if}}</td>\r\n        <td class=\"mono\">{{#if subCostCenterText}}{{subCostCenterText}}{{else}}—{{/if}}</td>\r\n        <td class=\"right nowrap\">{{debitText}}</td>\r\n        <td class=\"right nowrap\">{{creditText}}</td>\r\n      </tr>\r\n      {{/each}}\r\n    </tbody>\r\n  </table>\r\n\r\n  <!-- Totals -->\r\n  <div class=\"totals\">\r\n    <div class=\"total-box\">\r\n      <div class=\"label\">{{lookup context.resources \"labels.totalDebit\"}}</div>\r\n      <div class=\"value right\">{{model.totals.debitText}}</div>\r\n    </div>\r\n\r\n    <div class=\"total-box\">\r\n      <div class=\"label\">{{lookup context.resources \"labels.totalCredit\"}}</div>\r\n      <div class=\"value right\">{{model.totals.creditText}}</div>\r\n    </div>\r\n\r\n    <div class=\"total-box\">\r\n      <div class=\"label\">{{lookup context.resources \"labels.balance\"}}</div>\r\n      <div class=\"value right\">{{model.totals.diffText}}</div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- Footer (Reporte izq / Generado der) -->\r\n  <div class=\"footer\">\r\n    <div>\r\n      Reporte: <span class=\"mono\">{{context.metadata.ReportKey}}</span>\r\n    </div>\r\n    <div>\r\n      Generado: <span class=\"mono\">{{context.metadata.GeneratedAtUtc}}</span>\r\n    </div>\r\n  </div>\r\n\r\n</body>\r\n</html>\r\n"},"property":"helpers","statusCode":400,"weak":true,"logged":true,"previousOperationId":"tzec05pxuem5ger","id":"z7syjghdt8zpm0b","stack":"Error: Asset /core/accounting/journal-entry/v3/styles.css not found\n  at module.exports (/app/node_modules/@jsreport/jsreport-core/lib/shared/createError.js:10:13)\n  at WorkerReporter.createError (/app/node_modules/@jsreport/jsreport-core/lib/shared/reporter.js:53:12)\n  at readAsset (/app/node_modules/@jsreport/jsreport-assets/lib/assetsShared.js:121:24)\n  at async Object.read (/app/node_modules/@jsreport/jsreport-assets/lib/worker.js:136:19)\n  at async Object.asset (system-helpers.js:293:20)\n  at async /app/node_modules/@jsreport/jsreport-core/lib/worker/render/executeEngine.js:284:28\n  at async Promise.all (index 0)\n  at async executionFn (/app/node_modules/@jsreport/jsreport-core/lib/worker/render/executeEngine.js:283:11)\n  at async run (/app/node_modules/@jsreport/jsreport-core/lib/worker/sandbox/createSandbox.js:132:18)\n  at async WorkerReporter.runInSandbox [as _runInSandbox] (/app/node_modules/@jsreport/jsreport-core/lib/worker/sandbox/runInSandbox.js:214:14)\n  at async executeEngine (/app/node_modules/@jsreport/jsreport-core/lib/worker/render/exec