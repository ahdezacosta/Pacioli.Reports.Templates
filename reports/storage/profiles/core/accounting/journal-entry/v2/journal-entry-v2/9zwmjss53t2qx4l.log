r\n        <div class=\"card\" style=\"grid-column: span 2;\">\r\n            <p class=\"label\">Descripción</p>\r\n            <p class=\"value\">{{#if header.description}}{{header.description}}{{else}}—{{/if}}</p>\r\n        </div>\r\n\r\n        <div class=\"card\" style=\"grid-column: span 2;\">\r\n            <p class=\"label\">Referencia</p>\r\n            <p class=\"value\">{{#if header.reference}}{{header.reference}}{{else}}—{{/if}}</p>\r\n        </div>\r\n\r\n        {{#if header.postedAtUtc}}\r\n        <div class=\"card\">\r\n            <p class=\"label\">Contabilizado (UTC)</p>\r\n            <p class=\"value\">{{fmtDateTime header.postedAtUtc}}</p>\r\n        </div>\r\n        {{else}}\r\n        <div class=\"card\">\r\n            <p class=\"label\">Contabilizado (UTC)</p>\r\n            <p class=\"value\">—</p>\r\n        </div>\r\n        {{/if}}\r\n\r\n        {{#if header.voidedAtUtc}}\r\n        <div class=\"card\">\r\n            <p class=\"label\">Anulado (UTC)</p>\r\n            <p class=\"value\">{{fmtDateTime header.voidedAtUtc}}</p>\r\n        </div>\r\n        {{else}}\r\n        <div class=\"card\">\r\n            <p class=\"label\">Anulado (UTC)</p>\r\n            <p class=\"value\">—</p>\r\n        </div>\r\n        {{/if}}\r\n    </div>\r\n\r\n    <div class=\"section-title\">Líneas</div>\r\n\r\n    <table>\r\n        <thead>\r\n            <tr>\r\n                <th style=\"width:22%;\">Cuenta</th>\r\n                <th>Descripción</th>\r\n                <th style=\"width:16%;\">Centro costo</th>\r\n                <th style=\"width:16%;\">Subcentro</th>\r\n                <th class=\"right nowrap\" style=\"width:12%;\">Débito</th>\r\n                <th class=\"right nowrap\" style=\"width:12%;\">Crédito</th>\r\n            </tr>\r\n        </thead>\r\n        <tbody>\r\n            {{#each lines}}\r\n            <tr>\r\n                <td>\r\n                    <div class=\"value mono\">{{shortGuid accountId}}</div>\r\n       