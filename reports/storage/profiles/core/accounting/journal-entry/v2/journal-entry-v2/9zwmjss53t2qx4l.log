;\r\n            align-items: center;\r\n            gap: 8px;\r\n            padding: 6px 10px;\r\n            border-radius: 999px;\r\n            font-size: 12px;\r\n            font-weight: 700;\r\n            border: 1px solid var(--line);\r\n            background: var(--soft);\r\n            white-space: nowrap;\r\n        }\r\n\r\n            .chip.ok {\r\n                color: var(--ok);\r\n                border-color: rgba(22,163,74,.25);\r\n                background: rgba(22,163,74,.08);\r\n            }\r\n\r\n            .chip.bad {\r\n                color: var(--bad);\r\n                border-color: rgba(220,38,38,.25);\r\n                background: rgba(220,38,38,.08);\r\n            }\r\n\r\n            .chip.warn {\r\n                color: var(--warn);\r\n                border-color: rgba(245,158,11,.25);\r\n                background: rgba(245,158,11,.10);\r\n            }\r\n\r\n        .meta {\r\n            display: grid;\r\n            grid-template-columns: repeat(4, 1fr);\r\n            gap: 10px;\r\n            margin: 10px 0 14px 0;\r\n        }\r\n\r\n        .card {\r\n            border: 1px solid var(--line);\r\n            border-radius: 12px;\r\n            background: #fff;\r\n            padding: 10px 12px;\r\n            min-height: 54px;\r\n        }\r\n\r\n        .label {\r\n            font-size: 11px;\r\n            color: var(--muted);\r\n            margin: 0 0 4px 0;\r\n        }\r\n\r\n        .value {\r\n            font-size: 13px;\r\n            font-weight: 700;\r\n            margin: 0;\r\n            word-break: break-word;\r\n        }\r\n\r\n            .value.mono {\r\n                font-family: var(--mono);\r\n                font-weight: 600;\r\n            }\r\n\r\n        .section-title {\r\n            font-size: 12px;\r\n            font-weight: 800;\r\n            letter-spacing: .25px;\r\n            text-transform: uppercase;\r\n            color: var(--muted);\r\n            margin: 16px 0 8px 